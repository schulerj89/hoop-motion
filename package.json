{
  "name": "kinerig-studio",
  "version": "1.3.1",
  "description": "Extract human pose motion and author Three.js humanoid rig profiles.",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1 --port 4297",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "python:setup": "node scripts/setupPython.mjs",
    "model:sample": "node scripts/createSampleModel.mjs",
    "pose:model": "node scripts/pythonRunner.mjs scripts/download_pose_model.py",
    "extract": "node scripts/pythonRunner.mjs scripts/extract_pose.py",
    "process": "tsx scripts/processMotion.ts",
    "pipeline": "tsx scripts/runPipeline.ts",
    "motion:search": "tsx scripts/acquireMotion.ts",
    "motion:acquire": "tsx scripts/acquireMotion.ts --download --process",
    "runs:index": "tsx scripts/runIndex.ts",
    "fixture:reach": "node scripts/pythonRunner.mjs scripts/generate_fixture_video.py --motion reach --output data/input/fixture_reach.mp4",
    "fixture:wave": "node scripts/pythonRunner.mjs scripts/generate_fixture_video.py --motion wave --output data/input/fixture_wave.mp4",
    "fixture:side-step": "node scripts/pythonRunner.mjs scripts/generate_fixture_video.py --motion side-step --output data/input/fixture_side_step.mp4",
    "fixture": "npm run fixture:reach && npm run fixture:wave && npm run fixture:side-step",
    "process:fixture:reach": "tsx scripts/runPipeline.ts --input data/input/fixture_reach.mp4 --name fixture-reach --synthetic-on-fail",
    "process:fixture:wave": "tsx scripts/runPipeline.ts --input data/input/fixture_wave.mp4 --name fixture-wave --synthetic-on-fail",
    "process:fixture:side-step": "tsx scripts/runPipeline.ts --input data/input/fixture_side_step.mp4 --name fixture-side-step --synthetic-on-fail",
    "process:fixtures": "npm run process:fixture:reach && npm run process:fixture:wave && npm run process:fixture:side-step && npm run runs:index",
    "screenshots": "playwright test tests/smoke/viewer.spec.ts tests/smoke/rigBuilder.spec.ts tests/smoke/acquire.spec.ts --project=chromium",
    "record:sample": "playwright test tests/smoke/realClipVideo.spec.ts --project=chromium",
    "smoke": "npm run python:setup && npm run model:sample && npm run fixture && npm run process:fixtures && npm run typecheck && npm run test && npm run build && npm run screenshots"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.35",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/node": "25.9.3",
    "@types/three": "0.184.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
